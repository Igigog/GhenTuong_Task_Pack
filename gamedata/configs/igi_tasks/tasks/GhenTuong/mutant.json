{
	"WTF_VERSION": "4.2",
	"CREDITS": "GhenTuong - idea and initial implementation\\nIgigog - support",
	"description": {
		"locations": ["$ igi_description.get_smart_name_by_id(|frame.smart_id|)"]
	},
	"frames": [
	{
		"src": "GhenTuong/assault_smart_with_squad.json",
		"smart_id": "$ wtf.shuffle(igi_finder.get_smarts(1,1))[1]",
		"section_name":"$ igi_utils.random_table_value(|this.sections|)",

		"squad_size": 4,
		"mutants_section": "$ 'gt_mutant_'..wtf_gt_tasks.scale_to_player()",
		"sections": "@$ igi_helper.db_ini:collect_section(|this.mutants_section|)",
		"link_id": "frame"
	}
	],
	"rewards": {
		"money": "@$ 3000 + 200 * |frame.squad_size|",
		"goodwill": "@$ 30 + 2 * |frame.squad_size|"
	},
	"icon": "ui_iconsTotal_mutant",
	"quest_givers": [
		{"Mechanic": true}
	]
}