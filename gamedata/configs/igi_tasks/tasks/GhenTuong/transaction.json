{
	"WTF_VERSION": "4.3",
	"CREDITS": "GhenTuong - idea and initial implementation\\nIgigog - support",
	"preconditions": [
		"$ db.actor:character_rank() >= 5000"
	],
	"description": {
		"locations": ["$ igi_description.get_smart_name_by_id(|frame.smart_id|)"],
		"factions": ["$ |frame.enemy_faction|", "$ |frame.friend_faction|"]
	},
	"frames": [
	{
		"src": "GhenTuong/transaction.json",
		"_smart_ids": "$ igi_finder.get_smarts(1,1)",
		"smart_id": "?$ wtf.shuffle(|this._smart_ids|)[1]",
		"treasure_section": "$ igi_utils.choose('gt_package_weapon','gt_package_artifact')",
		"enemy_faction": "$ igi_macros.Faction(|CACHE.task_giver_id|, 'enemy of taskgiver and enemy of actor')",
		"friend_faction":"$ igi_macros.Faction(|CACHE.task_giver_id|, 'enemy of |this.enemy_faction|')",
		"enemies_count": 6,
		"link_id": "frame"
	}
	],
	"icon": "ui_inGame2_Sdelka",
	"rewards": {
		"money": "@$ 6000 + 400 * |frame.enemies_count|",
		"goodwill": "@$ 60 + 4 * |frame.enemies_count|"
	},
	"quest_givers": [
		{"Mechanic": true}
	]
}