{
	"WTF_VERSION": "4.3",
	"CREDITS": "GhenTuong - idea and initial implementation\\nIgigog - support",
	"description": {
		"locations": ["$ igi_description.get_smart_name_by_id(|frame.smart_id|)"],
		"factions": ["$ |frame.faction|"]
	},
	"frames": [
	{
		"src": "GhenTuong/kill_squad.json",
		"smart_id": "$ wtf.shuffle(igi_finder.get_smarts(1,1))[1]",
		"section_name":"$ 'gt_stalker_heavy_' .. wtf_gt_tasks.scale_to_player() .. '_' .. |this.faction|",
		"squad_size": 4,
		"link_id": "frame",

		"faction":"$ igi_macros.Faction(|CACHE.task_giver_id|, 'enemy of actor and enemy of taskgiver')"
	}
	],
	"icon": "ui_inGame2_PD_master_boevih_sistem",
	"rewards": {
		"money": "@$ 2000 + 400 * |frame.squad_size|",
		"goodwill": "@$ 20 + 4 * |frame.squad_size|"
	},
	"quest_givers": [
		{"Mechanic": true}
	]
}