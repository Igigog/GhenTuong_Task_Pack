{
	"WTF_VERSION": "4.2",
	"CREDITS": "GhenTuong - idea and initial implementation\\nIgigog - support",
	"preconditions": [
		"$ db.actor:community_goodwill(igi_helper.get_community_by_id(|CACHE.task_giver_id|)) >= 300"
	],
	"description": {
		"locations": ["$ dynamic_news_helper.GetPointDescription(|item.se_parent|)"],
		"factions": ["$ alife_character_community(|item.se_parent|)"],
		"targets": ["$ igi_description.item_name_by_id(|item.id|)"]
	},
	"entities": [
	{
		"ids": "$ igi_finder.find_items_in_enemy(1, 2, igi_helper.db_ini:collect_section('f_gt_weapon_' .. tostring(wtf_gt_tasks.scale_to_player())))",
		"condition_after": "$ igi_random.rand(70, 90)",
		"id": "?$ wtf.shuffle(|this.ids|)[1]",
		"se_parent": "@$ alife_object(alife_object(|this.id|).parent_id)",
		"CONTROLLER": "@$ igi_target_get.Get",
		"HELPERS": ["@$ wtf.Repair(|this.condition_after|)"],
		"link_id": "item"
	}
	],
	"rewards": {
		"money": 0,
		"goodwill": 30
	},
	"icon": "ui_inGame2_Neizvestnoe_oruzhie",
	"quest_givers": [
		{"Mechanic": true}
	]
}